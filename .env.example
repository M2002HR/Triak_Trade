APP_NAME=Triak_Trade
APP_ENV=dev
LOG_LEVEL=INFO
LOG_FORMAT=human
DATABASE_URL=mysql+pymysql://triak:triak_local_password@localhost:3306/triak_trade
TEST_DATABASE_URL=mysql+pymysql://triak:triak_local_password@localhost:3306/triak_trade_test
REDIS_URL=redis://localhost:6379/0
EXECUTION_MODE=demo
TOOBIT_BASE_URL=https://api.toobit.com
TOOBIT_API_KEY=replace_me
TOOBIT_API_SECRET=replace_me
TELEGRAM_API_ID=123456
TELEGRAM_API_HASH=replace_me
TELEGRAM_SESSION_NAME=triak_trade
TELEGRAM_SESSION_DIR=.sessions
TELEGRAM_HISTORY_BATCH_SIZE=100
TELEGRAM_LIVE_CHANNELS=
TELEGRAM_REAL_TEST_CHANNEL=https://t.me/Tofan_Trade
RUN_TELEGRAM_INTEGRATION_TESTS=0
TELEGRAM_BOT_TOKEN=replace_me
ADMIN_USER_IDS=111111111,222222222
GEMINI_API_KEYS=replace_me_1,replace_me_2
GROQ_API_KEYS=replace_me_1,replace_me_2
SIGNAL_CONSOLIDATION_SECONDS=180
SIGNAL_MAX_UPDATE_WINDOW_HOURS=48
CHANNEL_AGENT_CONTEXT_MESSAGE_LIMIT=50
AI_GATEWAY_ENABLED=false
AI_GATEWAY_BASE_URL=http://localhost:8000
AI_GATEWAY_TIMEOUT_SECONDS=30
AI_GATEWAY_PROVIDER_PRIORITY=gemini,groq
AI_GATEWAY_DEFAULT_MODEL=
AI_GATEWAY_CLASSIFY_PATH=/v1/classify/telegram-signal
AI_CLASSIFIER_ENABLED=false
AI_CLASSIFIER_MIN_CONFIDENCE=0.70
AI_CLASSIFIER_USE_REGEX_FALLBACK=true
AI_CLASSIFIER_STORE_PROMPT_TEXT=false
AI_CLASSIFIER_STORE_RESPONSE_TEXT=false
AI_REAL_TEST_CHANNEL=https://t.me/Tofan_Trade
MAX_RISK_PER_TRADE_PCT=1.0
MAX_DAILY_LOSS_PCT=3.0
MAX_WEEKLY_LOSS_PCT=6.0
